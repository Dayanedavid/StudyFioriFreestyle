<mvc:View controllerName="zov.controller.View1"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns:t="sap.ui.table"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">
        <Button text="Hello World" press="onPress"/>

        <VBox class="sapUiTinyMargin">
            <Label text="Id do Cliente"/>
            <Input />
        </VBox>

        <t:Table id="table1"
            rows="{/ZC_DD_CAB}"
            visibleRowCount="10"
            threshold="10"
            class="sapUiTinyMargin"
            selectionMode="MultiToggle">
            <t:toolbar>
                <OverflowToolbar>
                    <Title id="title" text="Ordens"></Title>
                </OverflowToolbar>
            </t:toolbar>
            <t:columns>
                <t:Column width="4rem" sortProperty="Ordemid">
                    <Label text="Ordemid" />
                    <t:template>
                        <Text text="{Ordemid}" wrapping="false" />
                    </t:template>
                </t:Column>
                <t:Column width="10rem" sortProperty="Clienteid" filterProperty="Clienteid" autoResizable="true">
                    <Label text="Id do cliente" />
                    <t:template>
                        <Text text="{Clienteid}" wrapping="false" />
                    </t:template>
                </t:Column>
                <t:Column width="10rem" sortProperty="TotaiItens" filterProperty="Totalitens" autoResizable="true">
                    <Label text="Total Itens" />
                    <t:template>
                        <Text text="{Totalitens}" wrapping="false" />
                    </t:template>
                </t:Column>
            </t:columns>
        </t:Table>
    </Page>
</mvc:View>